# =============================================================================
# API Scheduler Flow Engine — Environment Configuration
# Salin file ini ke .env dan isi sesuai environment
# JANGAN commit .env ke version control
# =============================================================================

# --- Server ---
SERVER_PORT=8080

# --- Database ---
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgrespassword
DB_NAME=flow_engine
DB_SSL_MODE=disable

# --- Redis ---
REDIS_URL=redis:6379

# --- JWT ---
# Generate dengan: openssl rand -base64 64
JWT_SECRET=aAFSmO5lDRkWiXj/MjE+KiLdoOjBdxFbHvUwI1gZ7OIH2zzMjTGT3CHkxTzSO8Hr0RaS7nqX/8TjHdYYFtwDHQ==

# --- Worker Pool ---
WORKER_POOL_SIZE=10

# --- Scheduler ---
TIMEZONE=Asia/Jakarta

# --- Execution ---
# Timeout per execution dalam detik (default: 300 = 5 menit)
EXECUTION_TIMEOUT_SECONDS=300

# Jumlah retry default per step jika tidak di-set di flow config
DEFAULT_RETRY_COUNT=3

# Delay antar retry dalam detik
DEFAULT_RETRY_DELAY_SECONDS=5

# Behaviour saat step gagal: "stop" (skip step berikutnya) | "continue" (lanjut)
FAILURE_POLICY=stop

# --- Logging ---
LOG_LEVEL=info
# LOG_FILE=/var/log/flow-engine/app.log  # opsional, default ke stdout
